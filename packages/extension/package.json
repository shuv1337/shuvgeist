{
	"name": "@shuvgeist/extension",
	"version": "2.0.0",
	"private": true,
	"description": "Shuvgeist Chrome extension runtime and user interface",
	"type": "module",
	"exports": {
		".": "./src/background.ts",
		"./*": "./src/*.ts"
	},
	"scripts": {
		"build": "node ./scripts/build.mjs && tailwindcss -i ./src/app.css -o ../../dist-chrome/app.css --minify",
		"dev": "concurrently -n \"build,css,server\" -c \"blue,green,yellow\" \"node ./scripts/build.mjs --watch\" \"tailwindcss -i ./src/app.css -o ../../dist-chrome/app.css --watch\" \"node ./scripts/dev-server.mjs\"",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"dependencies": {
		"@mariozechner/jailjs": "^0.1.0",
		"@mariozechner/mini-lit": "file:../../../mini-lit",
		"@shuv1337/pi-agent-core": "0.78.0",
		"@shuv1337/pi-ai": "0.78.0",
		"@shuv1337/pi-web-ui": "0.78.0",
		"@shuvgeist/driver": "2.0.0",
		"@shuvgeist/protocol": "2.0.0",
		"chart.js": "^4.5.1",
		"docx-preview": "^0.3.7",
		"fuse.js": "^7.1.0",
		"highlight.js": "^11.11.1",
		"js-interpreter": "^6.0.1",
		"jszip": "^3.10.1",
		"lit": "^3.3.1",
		"lucide": "^0.544.0",
		"minimatch": "^10.0.3",
		"ollama": "^0.6.0",
		"pdfjs-dist": "5.4.394",
		"three": "^0.180.0",
		"xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
	},
	"devDependencies": {
		"@tailwindcss/cli": "^4.0.0-beta.14",
		"@types/chrome": "^0.1.24",
		"@types/webextension-polyfill": "^0.12.4",
		"concurrently": "^9.2.1",
		"esbuild": "^0.25.10",
		"typescript": "^5.9.3",
		"ws": "^8.18.0"
	}
}
