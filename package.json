{
	"name": "@shuvgeist/root",
	"version": "2.0.0",
	"private": true,
	"description": "Shuvgeist browser automation workspace",
	"type": "module",
	"workspaces": [
		"packages/*",
		"proxy",
		"site"
	],
	"scripts": {
		"clean": "rm -rf dist-chrome dist-cli dist-cli-package",
		"build:chrome": "npm run build --workspace @shuvgeist/extension",
		"build:cli": "npm run build --workspace shuvgeist",
		"package:cli": "npm run package --workspace shuvgeist",
		"build": "npm run build:chrome",
		"dev": "npm run dev --workspace @shuvgeist/extension",
		"typecheck": "npm run typecheck --workspaces --if-present",
		"typecheck:node": "npm run typecheck --workspace @shuvgeist/protocol --workspace @shuvgeist/driver --workspace @shuvgeist/server --workspace shuvgeist",
		"test": "npm run test:unit && npm run test:integration",
		"test:unit": "vitest run tests/unit proxy/tests",
		"test:integration": "vitest run tests/integration",
		"test:component": "vitest run --environment happy-dom tests/component",
		"test:coverage": "vitest run tests/unit tests/integration proxy/tests --coverage --exclude tests/integration/bridge/headless-direct-cdp-runtime.test.ts",
		"test:e2e": "playwright test",
		"test:e2e:extension": "playwright test tests/e2e/extension",
		"test:e2e:site": "playwright test tests/e2e/site",
		"bench:agent-eval": "tsx benchmarks/agent-eval/cli.ts",
		"count-tokens": "tsx scripts/count-tokens.ts",
		"check:boundaries": "node scripts/check-workspace-boundaries.mjs",
		"check": "biome check --write . && npm run check:boundaries && npm run typecheck && npm run test:unit && npm run test:integration && npm run check --workspace shuvgeist-site",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/cli": "^4.0.0-beta.14",
		"@types/chrome": "^0.1.24",
		"@types/node": "^22.16.0",
		"@types/webextension-polyfill": "^0.12.4",
		"@types/ws": "^8.18.1",
		"@vitest/coverage-v8": "^4.1.0",
		"concurrently": "^9.2.1",
		"esbuild": "^0.25.10",
		"happy-dom": "^20.8.4",
		"husky": "^9.1.7",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0",
		"ws": "^8.18.0"
	}
}
